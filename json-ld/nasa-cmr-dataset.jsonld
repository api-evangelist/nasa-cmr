  "@type": "DataCatalog",
  "@id": "https://cmr.earthdata.nasa.gov",
  "name": "NASA Common Metadata Repository (CMR)",
  "description": "NASA's Common Metadata Repository is a high-performance metadata system that catalogs all Earth science data collections and granules at NASA. It provides search, ingest, access control, and discovery interfaces for the full NASA Earthdata catalog.",
  "url": "https://www.earthdata.nasa.gov/about/esdis/eosdis/cmr",
  "provider": {
    "@type": "Organization",
    "name": "NASA Earth Science Data and Information System (ESDIS)",
    "url": "https://www.earthdata.nasa.gov",
    "parentOrganization": {
      "@type": "Organization",
      "name": "National Aeronautics and Space Administration (NASA)",
      "url": "https://www.nasa.gov"
    }
  },
  "license": "https://www.earthdata.nasa.gov/engage/open-data-services-software",
  "keywords": [
    "NASA",
    "Earth Science",
    "Satellite Data",
    "Remote Sensing",
    "Geospatial",
    "Metadata",
    "STAC",
    "OpenSearch"
  ],
